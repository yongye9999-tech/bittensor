.card {
  background: #1E1E2F;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.5);
}
.card-img {
  width: 100%;
  height: 280rpx;
}
.card-info {
  padding: 20rpx;
}
.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #D4AF37;
}
.price {
  display: block;
  font-size: 28rpx;
  color: #FFD700;
  margin: 10rpx 0;
}
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.tag {
  background: #333;
  color: #ccc;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
