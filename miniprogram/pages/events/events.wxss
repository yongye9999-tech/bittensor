.event-card {
  background: #1E1E2F;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.event-img {
  width: 100%;
  height: 300rpx;
}
.event-info {
  padding: 20rpx;
}
.event-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #D4AF37;
}
.event-desc {
  display: block;
  color: #ccc;
  margin: 10rpx 0;
  font-size: 26rpx;
}
.event-time {
  color: #aaa;
  font-size: 22rpx;
}
