<view class="container">
  <view class="room-info" wx:if="{{roomName}}">
    <text class="room-name">{{roomName}}</text>
    <text class="room-price">¥{{price}}/小时</text>
  </view>

  <view class="form">
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="picker">预约日期：{{date || '请选择日期'}}</view>
    </picker>
    <picker mode="multiSelector" range="{{timeRange}}" value="{{timeIndex}}" bindchange="onTimeChange" bindcolumnchange="onColumnChange">
      <view class="picker">时间：{{selectedTime || '请选择时间段'}}</view>
    </picker>
    <view class="input-group">
      <text class="label">联系人</text>
      <input class="input" placeholder="请输入您的姓名" value="{{contactName}}" bindinput="onInputName" />
    </view>
    <view class="input-group">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onInputPhone" />
    </view>
    <button class="submit-btn" bindtap="submitReservation">立即预约</button>
  </view>
</view>
