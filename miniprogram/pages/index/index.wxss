.banner {
  width: 100%;
  height: 360rpx;
  margin-bottom: 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
}
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #D4AF37;
  border-left: 8rpx solid #D4AF37;
  padding-left: 20rpx;
}
.empty {
  text-align: center;
  color: #888;
  margin-top: 100rpx;
}
