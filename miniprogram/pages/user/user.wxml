<view class="container">
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" />
    <view class="user-detail">
      <text class="nickname">{{userInfo.nickName || '点击登录'}}</text>
      <button class="login-btn" wx:if="{{!hasLogin}}" bindtap="getUserProfile">授权登录</button>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="goMyReservations">
      <text>我的预约</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goCoupons">
      <text>优惠券</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="callService">
      <text>联系客服</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
